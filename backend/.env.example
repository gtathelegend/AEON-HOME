# ÆON Home Backend Environment Config
# Copy this file to .env in the backend folder.

AEON_DEVICE_ID=aeon-home-001
AEON_OWNER_ID=your-user-id
AEON_API_HOST=0.0.0.0
AEON_API_PORT=8000
AEON_SERIAL_PORT=/dev/ttyUSB0
AEON_SERIAL_BAUD=115200
AEON_USE_NPU=true
AEON_MODEL_DIR=models/bin
AEON_MEMORY_DB=data/aeon_memory.db
AEON_JWT_SECRET=CHANGE_ME_IN_PRODUCTION
AEON_JWT_ALG=HS256
AEON_JWT_EXPIRE=3600
SARVAM_API_KEY=
SARVAM_OFFLINE=true
AEON_CLOUD_SYNC=false
AEON_METRICS_PORT=9090
AEON_DEMO_MODE=false
AEON_SEED_DATABASE=false
