# ÆON Home — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Identity ──────────────────────────────────────────────────────────────────
AEON_DEVICE_ID=aeon-home-001
AEON_OWNER_ID=your-user-id

# ── API server ────────────────────────────────────────────────────────────────
AEON_API_HOST=0.0.0.0
AEON_API_PORT=8000

# ── Serial bridge ─────────────────────────────────────────────────────────────
# Linux: /dev/ttyUSB0 or /dev/ttyACM0
# Windows: COM3 (check Device Manager)
AEON_SERIAL_PORT=/dev/ttyUSB0
AEON_SERIAL_BAUD=115200

# ── QNN / NPU ─────────────────────────────────────────────────────────────────
AEON_USE_NPU=true
AEON_MODEL_DIR=backend/models/bin

# ── Persistence ───────────────────────────────────────────────────────────────
AEON_MEMORY_DB=backend/data/aeon_memory.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
AEON_JWT_SECRET=CHANGE_ME_IN_PRODUCTION
AEON_JWT_ALG=HS256
AEON_JWT_EXPIRE=3600

# ── Voice (Sarvam AI) ─────────────────────────────────────────────────────────
# Get your key at https://dashboard.sarvam.ai
SARVAM_API_KEY=
# Set to false to use the Sarvam cloud API; true for offline-only mode
SARVAM_OFFLINE=true

# ── Cloud AI 100 (optional) ───────────────────────────────────────────────────
# Set to true ONLY if you want background model optimisation via Cloud AI 100.
# Privacy note: only model weight deltas are transmitted, never sensor data.
AEON_CLOUD_SYNC=false
AEON_CLOUD_ENDPOINT=

# ── Metrics ───────────────────────────────────────────────────────────────────
AEON_METRICS_PORT=9090

# ── Demo & Seeding ────────────────────────────────────────────────────────────
# Set to true to generate and display simulated telemetry/event data in offline mode
AEON_DEMO_MODE=false
# Set to true to automatically seed the database on startup if empty
AEON_SEED_DATABASE=false

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8001
